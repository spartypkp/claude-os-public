venv/
venv-test/
.env

# Only ignore PDFs in Documents and Logs (not Desktop)
Desktop/**/*.pdf
Logs/**/*.pdf

**/*.docx
**/*.csv

**/*.pyc
**/__pycache__/
.DS_Store
temp-src/

# Session/mission execution temp files (never committed)
.engine/tmp/

# Trash folder (soft-deleted files)
Workspace/.trash/

# Worker execution artifacts (reports stored in DB)
.engine/data/outputs/
.engine/data/archives/

# Async worker logs (ephemeral)
.engine/logs/async/

# External file uploads (drag-drop into ClaudePanel)
.engine/data/uploads/

# Playwright skill temp execution scripts and dependencies
.claude/skills/playwright-skill/.temp-execution-*.js
.claude/skills/playwright/.temp-execution-*.js
.claude/skills/playwright/node_modules/

# User data (personal, never commit)
Desktop/IDENTITY.md
Desktop/MEMORY.md
Desktop/TODAY.md
Desktop/logs/
.engine/data/db/*.db
.engine/data/db/*.db-wal
.engine/data/db/*.db-shm
.engine/data/system.db
.engine/data/logs/
.mcp.json

# Specialist workspaces (ephemeral, never commit)
Desktop/conversations/[0-9][0-9][0-9][0-9]-*/

# Keep examples
!Desktop/IDENTITY.md.example
!Desktop/MEMORY.md.example
!Desktop/TODAY.md.example
!.mcp.json.example

# Exceptions - always track these
!**/resume.pdf

temp-parliament-experiments/