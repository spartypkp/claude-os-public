# Claude OS Environment Configuration
# Copy this file to .env and fill in your values
#
# IMPORTANT: Never commit .env with real credentials!

# ==============================================================================
# OPTIONAL - Telegram Integration
# ==============================================================================

# Telegram Bot Token (for Telegram integration)
# Create a bot via @BotFather on Telegram to get this token
# TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram User ID (for receiving messages)
# Send a message to @userinfobot on Telegram to get your user ID
# TELEGRAM_USER_ID=your-user-id-here

# Group Chat Support (optional)
# To enable group chats: add bot to a group, send a message, check bot logs for chat_id
# IMPORTANT: Disable bot privacy via @BotFather (/setprivacy -> Disable) so bot sees all messages
# TELEGRAM_GROUP_CHAT_ID=your-group-chat-id-here

# Additional authorized users for group chat (comma-separated Telegram user IDs)
# The owner (TELEGRAM_USER_ID) is always authorized -- list others here
# TELEGRAM_AUTHORIZED_USERS=123456789,987654321


# ==============================================================================
# ADVANCED - Typically not needed
# ==============================================================================

# Backend API port (default: 5001)
# CLAUDE_OS_PORT=5001

# Dashboard port (default: 3000)
# DASHBOARD_PORT=3000

# Dashboard API URL (must match backend port if changed)
# NEXT_PUBLIC_API_URL=http://localhost:5001

# Database path (default: .engine/data/db/system.db)
# DATABASE_PATH=.engine/data/db/system.db

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
